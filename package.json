{
  "name": "aws-sdk-vitest-mock",
  "version": "1.0.63",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.cjs"
      }
    },
    "./vitest-setup": {
      "import": "./vitest-setup.js",
      "require": "./vitest-setup.cjs"
    }
  },
  "license": "MIT",
  "author": "sudokar",
  "scripts": {
    "ci": "bun install --frozen-lockfile",
    "prepare": "husky",
    "prepublishOnly": "HUSKY=0",
    "lint": "nx lint",
    "lint:fix": "nx lint --fix",
    "test": "nx test",
    "build": "nx build",
    "docs": "typedoc && touch docs/.nojekyll",
    "docs:watch": "typedoc --watch",
    "docs:serve": "bun run docs && bunx http-server docs -o"
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1069.0",
    "@aws-sdk/client-dynamodb": "3.1075.0",
    "@aws-sdk/client-s3": "3.1050.0",
    "@aws-sdk/lib-dynamodb": "3.1064.0",
    "@aws-sdk/types": "3.973.8",
    "@nx/js": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.1",
    "@nx/workspace": "22.6.5",
    "@smithy/smithy-client": "^2.1.11",
    "@smithy/types": "4.14.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.40",
    "@swc/helpers": "0.5.23",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "nx": "22.7.5",
    "nx-oxlint": "^0.1.1",
    "oxlint": "^1.71.0",
    "prettier": "3.8.4",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@aws-sdk/core": "^3",
    "vitest": "^3 || ^4"
  }
}
