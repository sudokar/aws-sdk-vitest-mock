{
  "name": "aws-sdk-vitest-mock",
  "version": "1.0.52",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.cjs"
      }
    },
    "./vitest-setup": {
      "import": "./vitest-setup.js",
      "require": "./vitest-setup.cjs"
    }
  },
  "license": "MIT",
  "author": "sudokar",
  "scripts": {
    "ci": "bun install --frozen-lockfile",
    "prepare": "husky",
    "prepublishOnly": "HUSKY=0",
    "lint": "nx lint",
    "lint:fix": "nx lint --fix",
    "test": "nx test",
    "build": "nx build",
    "docs": "typedoc && touch docs/.nojekyll",
    "docs:watch": "typedoc --watch",
    "docs:serve": "bun run docs && bunx http-server docs -o"
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1013.0",
    "@aws-sdk/client-dynamodb": "3.1005.0",
    "@aws-sdk/client-s3": "3.1009.0",
    "@aws-sdk/lib-dynamodb": "3.1013.0",
    "@aws-sdk/types": "3.973.1",
    "@eslint/js": "10.0.1",
    "@nx/eslint": "22.4.2",
    "@nx/eslint-plugin": "22.6.0",
    "@nx/js": "22.5.4",
    "@nx/vite": "22.6.0",
    "@nx/vitest": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@smithy/types": "4.13.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@types/eslint-plugin-security": "3.0.1",
    "@types/node": "24.10.13",
    "@typescript-eslint/parser": "8.57.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.9",
    "eslint": "9.39.2",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.1",
    "eslint-plugin-unicorn": "63.0.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.2.7",
    "nx": "22.5.4",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "8.0.0",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@aws-sdk/core": "^3",
    "vitest": "^3 || ^4"
  }
}
